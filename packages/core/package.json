{
  "name": "@wiki-core/core",
  "version": "0.1.0",
  "description": "wiki-core core types, hooks, plugin manifest, and noise helpers",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./utils/noise": {
      "types": "./dist/utils/noise.d.ts",
      "import": "./dist/utils/noise.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}
