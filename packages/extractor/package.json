{
  "name": "@wiki-core/extractor",
  "version": "0.1.0",
  "description": "wiki-core extractor — DocumentTree 계층 탐색 + ContentRange 표준 + tree/vector/hybrid 추출 전략",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@wiki-core/core": "workspace:*",
    "@wiki-core/router": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}
