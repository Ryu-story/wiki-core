{
  "name": "@wiki-core/storage",
  "version": "0.1.0",
  "description": "wiki-core storage adapter — Postgres reference + StorageRouter base impl",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./postgres": {
      "types": "./dist/postgres.d.ts",
      "import": "./dist/postgres.js"
    },
    "./router": {
      "types": "./dist/router.d.ts",
      "import": "./dist/router.js"
    },
    "./migrations/*": "./src/migrations/*"
  },
  "files": [
    "dist",
    "src/migrations"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@wiki-core/core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}
